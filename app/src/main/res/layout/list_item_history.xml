<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="190dp">

    <ImageView
        android:id="@+id/history_item_bg"
        android:layout_width="0dp"
        android:layout_height="0dp"
        android:layout_marginStart="16dp"
        android:layout_marginTop="8dp"
        android:layout_marginEnd="16dp"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent"
        app:srcCompat="@drawable/list_item_vehicle_shape" />

    <TextView
        android:id="@+id/history_vehicle_model"
        style="@style/vehicle_list_main"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_marginStart="16dp"
        android:layout_marginTop="16dp"
        android:layout_marginEnd="8dp"
        android:textColor="@color/kawhite"
        app:layout_constraintEnd_toStartOf="@+id/history_date"
        app:layout_constraintStart_toStartOf="@+id/history_item_bg"
        app:layout_constraintTop_toTopOf="@+id/history_item_bg" />

    <TextView
        android:id="@+id/history_date"
        style="@style/text_info"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginEnd="16dp"
        android:textColor="@color/kawhite"
        app:layout_constraintBaseline_toBaselineOf="@+id/history_vehicle_model"
        app:layout_constraintEnd_toEndOf="@+id/history_item_bg" />

    <TextView
        android:id="@+id/history_location"
        style="@style/text_info"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_marginStart="16dp"
        android:layout_marginTop="8dp"
        android:layout_marginEnd="16dp"
        android:textColor="@color/kawhite"
        app:layout_constraintEnd_toEndOf="@+id/history_item_bg"
        app:layout_constraintStart_toStartOf="@+id/history_item_bg"
        app:layout_constraintTop_toBottomOf="@+id/history_vehicle_model" />

    <TextView
        android:id="@+id/history_price"
        style="@style/text_info"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginStart="16dp"
        android:textColor="@color/kawhite"
        app:layout_constraintBaseline_toBaselineOf="@+id/history_total_paid"
        app:layout_constraintStart_toStartOf="@+id/history_item_bg" />

    <TextView
        android:id="@+id/history_total_paid"
        style="@style/text_info"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:textColor="@color/kawhite"
        app:layout_constraintBottom_toBottomOf="@+id/history_item_bg"
        app:layout_constraintEnd_toEndOf="@+id/history_item_bg"
        app:layout_constraintStart_toStartOf="@+id/history_item_bg"
        app:layout_constraintTop_toBottomOf="@+id/history_location"
        app:layout_constraintVertical_bias="0.55" />

    <TextView
        android:id="@+id/history_percent"
        style="@style/text_info"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginEnd="16dp"
        android:textColor="@color/kawhite"
        app:layout_constraintBaseline_toBaselineOf="@+id/history_total_paid"
        app:layout_constraintEnd_toEndOf="@+id/history_item_bg" />

</androidx.constraintlayout.widget.ConstraintLayout>
